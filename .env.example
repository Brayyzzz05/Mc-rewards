# Discord
DISCORD_TOKEN=your_discord_bot_token
CLIENT_ID=your_bot_application_id
# Optional: register commands to a single guild for instant updates (recommended for testing)
GUILD_ID=

# Database (Postgres)
DATABASE_URL=postgres://user:pass@host:5432/dbname

# Minecraft RCON (optional but required for in-game delivery)
RCON_HOST=127.0.0.1
RCON_PORT=25575
RCON_PASSWORD=your_rcon_password